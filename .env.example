# Database
DATABASE_URL=postgresql+psycopg://tennis:tennis@db:5432/tennis
# Pour dev local sans Docker, remplacer par :
# DATABASE_URL=sqlite:///./tennis.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Scraping
USER_AGENT=tennis-stats-bot/0.1 (contact@example.com)
SCRAPE_DELAY_SEC=2.0
SCRAPE_TIMEOUT_SEC=20
SCRAPE_MAX_RETRIES=3

# Scheduler
ENABLE_SCHEDULER=true
RANKINGS_CRON=0 6 * * *
MATCHES_CRON=30 6 * * *

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
